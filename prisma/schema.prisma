generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  PROVIDER
  ADMIN
}

enum PetSex {
  MALE
  FEMALE
}

enum ServiceType {
  WALKING
  DAYCARE
  BOARDING
  TRAINING
  GROOMING
  PET_SITTING
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum HealthRecordType {
  VACCINATION
  VET_VISIT
  TREATMENT
  MEDICATION
  ALLERGY
  SURGERY
  OTHER
}

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP
  SMS
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

model UserProfile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  fullName  String
  phone     String?
  avatarUrl String?
  role      UserRole @default(OWNER)
  city      String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pets             Pet[]             @relation("PetOwner")
  services         Service[]         @relation("ServiceProvider")
  ownerBookings    Booking[]         @relation("BookingOwner")
  providerBookings Booking[]         @relation("BookingProvider")
  writtenReviews   Review[]          @relation("ReviewAuthor")
  receivedReviews  Review[]          @relation("ReviewProvider")
  notifications    NotificationLog[] @relation("NotificationRecipient")

  @@index([role])
  @@index([city])
}

model Pet {
  id           String   @id @default(uuid()) @db.Uuid
  ownerId      String   @db.Uuid
  name         String
  species      String
  breed        String
  age          Int
  weight       Decimal  @db.Decimal(5, 2)
  sex          PetSex
  description  String?
  isSterilized Boolean  @default(false)
  isVaccinated Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner           UserProfile      @relation("PetOwner", fields: [ownerId], references: [userId], onDelete: Restrict)
  images          PetImage[]
  bookings        Booking[]
  healthRecords   HealthRecord[]
  matchPreference MatchPreference?

  @@index([ownerId])
  @@index([species])
  @@index([breed])
}

model PetImage {
  id        String   @id @default(uuid()) @db.Uuid
  petId     String   @db.Uuid
  imageUrl  String
  path      String?
  createdAt DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
}

model Service {
  id                String      @id @default(uuid()) @db.Uuid
  providerId        String      @db.Uuid
  type              ServiceType
  title             String
  description       String
  price             Decimal     @db.Decimal(10, 2)
  location          String
  availabilityNotes String?
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  provider UserProfile @relation("ServiceProvider", fields: [providerId], references: [userId], onDelete: Restrict)
  bookings Booking[]
  reviews  Review[]

  @@index([providerId])
  @@index([type])
  @@index([isActive])
  @@index([location])
}

model Booking {
  id            String        @id @default(uuid()) @db.Uuid
  petId         String        @db.Uuid
  serviceId     String        @db.Uuid
  ownerId       String        @db.Uuid
  providerId    String        @db.Uuid
  bookingDate   DateTime
  durationHours Int?
  status        BookingStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  pet      Pet         @relation(fields: [petId], references: [id], onDelete: Restrict)
  service  Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  owner    UserProfile @relation("BookingOwner", fields: [ownerId], references: [userId], onDelete: Restrict)
  provider UserProfile @relation("BookingProvider", fields: [providerId], references: [userId], onDelete: Restrict)
  review   Review?

  @@index([petId])
  @@index([serviceId])
  @@index([ownerId])
  @@index([providerId])
  @@index([status])
  @@index([bookingDate])
  @@index([providerId, bookingDate])
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  bookingId  String   @unique @db.Uuid
  serviceId  String   @db.Uuid
  providerId String   @db.Uuid
  authorId   String   @db.Uuid
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  booking  Booking     @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  service  Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  provider UserProfile @relation("ReviewProvider", fields: [providerId], references: [userId], onDelete: Restrict)
  author   UserProfile @relation("ReviewAuthor", fields: [authorId], references: [userId], onDelete: Restrict)

  @@index([serviceId])
  @@index([providerId])
  @@index([authorId])
  @@index([rating])
}

model HealthRecord {
  id          String           @id @default(uuid()) @db.Uuid
  petId       String           @db.Uuid
  type        HealthRecordType
  recordDate  DateTime
  description String
  notes       String?
  nextDueDate DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([type])
  @@index([recordDate])
}

model MatchPreference {
  id                 String   @id @default(uuid()) @db.Uuid
  petId              String   @unique @db.Uuid
  preferredBreed     String?
  preferredSex       PetSex?
  minAge             Int?
  maxAge             Int?
  preferredLocation  String?
  healthRequirements String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([preferredBreed])
  @@index([preferredLocation])
}

model NotificationLog {
  id          String              @id @default(uuid()) @db.Uuid
  recipientId String              @db.Uuid
  channel     NotificationChannel
  status      NotificationStatus  @default(QUEUED)
  title       String
  message     String
  payload     Json?
  sentAt      DateTime?
  createdAt   DateTime            @default(now())

  recipient UserProfile @relation("NotificationRecipient", fields: [recipientId], references: [userId], onDelete: Cascade)

  @@index([recipientId])
  @@index([status])
  @@index([createdAt])
}
